{
  "name": "quoteworthy",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source content automation for marketing consultants. Content AI wants to quote.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wow-solutions/Quoteworthy.git"
  },
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter './apps/web' dev",
    "build": "bun --filter './apps/web' build",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "bun --filter '*' lint"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  }
}
