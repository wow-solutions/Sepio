# Sepio — environment variables (example)
# Copy to .env.local (gitignored) and fill in real values.

# ─── Supabase ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LinkedIn — App #1 (personal profile publishing) ────────────────────
# Products: Share on LinkedIn + Sign In with LinkedIn OIDC
# Scopes: w_member_social, openid, profile, email
LINKEDIN_APP1_CLIENT_ID=
LINKEDIN_APP1_CLIENT_SECRET=
LINKEDIN_APP1_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback

# ─── LinkedIn — App #2 (Company Pages via Community Management API) ─────
# Status: pending review (submitted 2026-05-11). Will be used after approval.
LINKEDIN_APP2_CLIENT_ID=
LINKEDIN_APP2_CLIENT_SECRET=

# ─── Anthropic (Claude) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── DataForSEO ─────────────────────────────────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── fal.ai (image generation, Sprint 1) ────────────────────────────────
FAL_API_KEY=

# ─── Lemon Squeezy (billing, Sprint 1) ──────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ─── Inngest ────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Sentry (observability, Sprint 0 task #20) ──────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Pipeline service URL (Railway/Fly.io after task #15) ───────────────
PIPELINE_SERVICE_URL=http://localhost:8000
